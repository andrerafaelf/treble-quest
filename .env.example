# Public site URL used for canonical and Open Graph metadata.
PUBLIC_SITE_URL=https://treble.quest/

# Public leaderboard API origin used by the static frontend.
PUBLIC_API_BASE=https://api.treble.quest

# Google Analytics 4 Measurement ID, for example G-XXXXXXXXXX.
# GA only loads after the visitor accepts analytics consent.
PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag token:
# <meta name="google-site-verification" content="PASTE_THIS_VALUE" />
PUBLIC_GOOGLE_SITE_VERIFICATION=
